#!/usr/bin/env bash

# Conservative release-style profile that mimics a reasoning-heavy router-backed
# OSS model with strict token budgeting and aggressive job narrowing.

export CCR_AUTOSTART=0

export CLAUDE_MODEL_ALIAS="router-kimi-k2-conservative"
export CLAUDE_PERMISSION_MODE="bypassPermissions"
export CLAUDE_MAX_CHILDREN=2
export CLAUDE_CHILD_TIMEOUT_SEC=180

export ORCH_MAX_FILES_PER_JOB=1
export ORCH_MAX_JOBS=4
export ORCH_INVENTORY_LIMIT=8
export ORCH_EXECUTE_WORKERS=1
export ORCH_WORKER_MODE="auto"
export ORCH_MAX_CHILD_INVOCATIONS=10
export ORCH_MAX_RETRIES_PER_JOB=3
export ORCH_MAX_FAIL_REPLANS_PER_JOB=2
export ORCH_MAX_ROUTER_RECOVERY_REPLANS=2
export ORCH_MAX_FILE_LINES=2500
