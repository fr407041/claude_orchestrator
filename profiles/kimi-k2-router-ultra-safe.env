#!/usr/bin/env bash

# Ultra-safe profile for Kimi-K2.7-Code behind Claude Code Router.
# Goal: prioritize not overflowing context over throughput.

export CCR_AUTOSTART=0

export CLAUDE_MODEL_ALIAS="router-kimi-k2-ultra-safe"
export CLAUDE_PERMISSION_MODE="bypassPermissions"
export CLAUDE_MAX_CHILDREN=1
export CLAUDE_CHILD_TIMEOUT_SEC=180

export ORCH_MAX_FILES_PER_JOB=1
export ORCH_MAX_JOBS=3
export ORCH_INVENTORY_LIMIT=6
export ORCH_EXECUTE_WORKERS=1
export ORCH_WORKER_MODE="managed_single_file"
export ORCH_MAX_CHILD_INVOCATIONS=8
export ORCH_MAX_RETRIES_PER_JOB=2
export ORCH_MAX_FAIL_REPLANS_PER_JOB=1
export ORCH_MAX_ROUTER_RECOVERY_REPLANS=1
export ORCH_MAX_FILE_LINES=1200

# Guarded read settings for planner / investigation turns.
export GUARD_MAX_FILES=1
export GUARD_MAX_LINES_PER_FILE=80
export GUARD_MAX_BATCHES=1

# Keep provider timeouts long enough for slow reasoning models,
# but keep orchestration breadth extremely narrow.
export API_TIMEOUT_MS=600000
